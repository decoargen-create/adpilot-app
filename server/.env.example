# AdPilot Server Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3001
NODE_ENV=production

# JWT Authentication
JWT_SECRET=your-secure-jwt-secret-key-here

# Frontend Configuration (for OAuth redirects and CORS in production)
FRONTEND_URL=https://your-production-domain.com

# Meta Marketing API Configuration
# Get these from: https://developers.facebook.com/apps/
META_APP_ID=your-meta-app-id-here
META_APP_SECRET=your-meta-app-secret-here
META_REDIRECT_URI=https://your-production-domain.com/api/meta/callback

# Google OAuth Configuration (if using Google authentication)
# Get from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Optional: Database configuration
# SQLite is used by default (node:sqlite built-in)
DATABASE_PATH=./adpilot.db

# Optional: File upload configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads
